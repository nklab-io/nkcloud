# NkCloud environment configuration
# Copy this file to .env and customize as needed.
# Most values have sensible defaults — you can start with an empty .env file.

# File storage root (mapped via Docker volume)
# NKCLOUD_FILE_ROOT=/data

# Session secret (auto-generated on first start if not set)
# NKCLOUD_SESSION_SECRET=

# Database path
# NKCLOUD_DB_PATH=/app/data/nkcloud.db

# Thumbnail cache directory
# NKCLOUD_THUMB_DIR=/app/data/thumbs

# Chunked upload temp directory
# NKCLOUD_CHUNK_DIR=/app/data/chunks
