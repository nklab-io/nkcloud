  "help": {
    "title": "NkCloud Help",
    "browse_title": "File Browsing",
    "browse_desc": "Click a folder to enter it. Use the breadcrumb bar at the top to jump back.<br>Toggle between <b>list</b> and <b>grid</b> view. Sort by name, size, or date modified.",
    "select_title": "Selecting Files",
    "select_desc": "<b>Click checkbox</b> — Toggle single item<br><b>Ctrl + Click</b> (Mac: ⌘ + Click) — Toggle multiple<br><b>Shift + Click</b> — Select range<br><b>Ctrl + A</b> (Mac: ⌘ + A) — Select all / deselect all<br><b>Esc</b> — Clear selection<br>A toolbar appears when items are selected for batch <b>download, move, delete</b>.",
    "upload_title": "Upload",
    "upload_desc": "Click the <b>Upload</b> button or <b>drag & drop</b> files onto the page.<br>Large files (> 20MB) are automatically chunked with progress display.",
    "download_title": "Download",
    "download_desc": "Click a file to download (media files preview first).<br>Right-click a folder to <b>Download as ZIP</b>.",
    "media_title": "Media Preview",
    "media_desc": "Images, videos, and audio open in a preview viewer.<br><b>← →</b> keys to navigate, <b>Esc</b> to close.",
    "share_title": "Sharing",
    "share_desc": "Right-click a file or folder → <b>Share</b>. Options:<br>• Password protection<br>• Expiry time<br>The generated link can be opened by anyone (no login required).",
    "context_title": "Right-Click Menu",
    "context_desc": "<b>Right-click</b> any file or folder for quick actions:<br>Open, download, preview, rename, share, move, delete.",
    "webdav_title": "WebDAV",
    "webdav_desc": "You can also mount NkCloud as a network drive via WebDAV.<br><b>macOS Finder</b>: Go → Connect to Server → Enter WebDAV URL<br><b>Credentials</b>: Your NkCloud username and password",
    "shortcuts_title": "Keyboard Shortcuts",
    "shortcut_select_all": "Select all / Deselect all",
    "shortcut_delete": "Delete selected items",
    "shortcut_escape": "Clear selection / Close preview",
    "shortcut_arrows": "Navigate prev/next in preview",
    "role_title": "Your Permissions",
    "role_owner_desc": "As <b>Owner</b>, you have full control:<br>• Browse and manage all files (root + all user homes)<br>• Upload, delete, move any file<br>• Create and revoke invite links<br>• Manage users (promote/demote, set quotas, disable/delete)<br>• View audit logs of all operations<br>• Create and manage share links",
    "role_admin_desc": "As <b>Admin</b>, you can:<br>• Browse all files (root + all user homes, root is read-only)<br>• Upload and manage files within user home directories<br>• Delete other users' files (but not the owner's)<br>• Create invite links for new users<br>• Create and manage share links<br><br>You <b>cannot</b>: upload to root, delete owner's files, manage users, or change quotas.",
    "role_user_desc": "As a <b>Member</b>, you can:<br>• Browse, upload, download, and delete files in your own directory<br>• Create share links for your files<br>• Search within your files<br>• Use WebDAV to access your directory<br><br>Your files are stored in a private home directory that only you and admins can see."
  }
